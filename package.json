{
  "name": "uncase",
  "version": "0.2.0",
  "description": "Wrapper of change-case to create case converter, validator and etc.",
  "keywords": [
    "camelCase",
    "capitalCase",
    "change-case",
    "constantCase",
    "converter",
    "dotCase",
    "kebabCase",
    "noCase",
    "pascalCase",
    "pascalSnakeCase",
    "pathCase",
    "sentenceCase",
    "snakeCase",
    "trainCase",
    "validate"
  ],
  "homepage": "https://github.com/ntnyq/uncase#readme",
  "bugs": {
    "url": "https://github.com/ntnyq/uncase/issues"
  },
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "repository": "ntnyq/uncase",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./is": {
      "types": "./dist/is.d.ts",
      "default": "./dist/is.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "coverage": "vitest --coverage",
    "dev": "tsdown --watch",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "release": "run-s release:check release:version",
    "release:check": "run-s format:check lint typecheck test",
    "release:version": "bumpp",
    "test": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "change-case": "^5.4.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260329.1",
    "@vitest/coverage-v8": "^4.1.2",
    "bumpp": "^11.0.1",
    "husky": "^9.1.7",
    "nano-staged": "^0.9.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.21.7",
    "vitest": "^4.1.2"
  },
  "nano-staged": {
    "*.{js,ts,mjs,tsx}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@10.33.0"
}
